<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime (required for notarization) + microphone access. vx-rs is a
         separate subprocess (not a loaded dylib), so no library-validation exception. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
